                MDCard:
                    style: "filled"
                    size_hint: (0.9, None) if root.width >= dp(465) else (0.97, None)
                    height: dp(140)
                    radius: dp(22)
                    pos_hint: {'center_x': 0.5}
                    id: card1

                    MDBoxLayout:
                        orientation: 'horizontal'
