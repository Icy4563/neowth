<CurrentWeatherScreen@MDScreen>:
    name: 'CurrentWeatherScreen'
    md_bg_color: app.theme_cls.backgroundColor

    MDFloatLayout:

        FitImage:
            source: "Graphics/sunny.png"
            size_hint: 0.8, None
            height: dp(415)
            opacity: 0.3
            pos_hint: {'center_x': 0.825,'center_y': 0.825}
            allow_stretch: True
            keep_ratio: True
            id: background_image

    MDScrollView:
        do_scroll_x: False
        do_scroll_y: True

        #full screen layout
        MDBoxLayout:
            orientation: "vertical"
            spacing: dp(25)
            padding: dp(5)
            height: self.minimum_height
            size_hint_y: None

            #Location text
            MDBoxLayout:
                orientation: "horizontal"
                size_hint: None, None
                height: self.minimum_height
                adaptive_height: True
                spacing: dp(20)
                padding: dp(24), dp(20), dp(32), dp(1)
                adaptive_width: True
                width: self.minimum_width
                # pos_hint: {'center_x': 0.1}
                halign: "left"
                valign: "top"

                Label:
                    text: "\ue55e"
                    font_name: "Material-Icons"
                    color: app.theme_cls.onSurfaceVariantColor
                    font_size: dp(33.5)
                    adaptive_size: True
                    size: self.texture_size[0], self.texture_size[1]


                MDLabel:
                    text: "Earth probably idk"
                    color: app.theme_cls.onSurfaceVariantColor
                    font_style: "ubuntu_title"
                    role: "large"
                    adaptive_size: True
                    size: self.texture_size[0], self.texture_size[1]
                    id: location_text
                    on_ref_press: app.open_city_search_menu()
                    markup: True

            # (new) rain text
            MDBoxLayout:
                orientation: "horizontal"
                size_hint: None, None
                height: self.minimum_height
                adaptive_height: True
                spacing: dp(20)
                padding: dp(24), dp(-11), dp(32), dp(2)
                adaptive_width: True
                width: self.minimum_width
                # pos_hint: {'center_x': 0.1}
                halign: "left"
                valign: "top"

                Label:
                    text: "\uf084"
                    font_name: "Material-Icons"
                    color: app.theme_cls.onSurfaceVariantColor
                    font_size: dp(33.5)
                    adaptive_size: True
                    size: self.texture_size[0], self.texture_size[1]

                MDLabel:
                    text: "none mm"
                    color: app.theme_cls.onSurfaceVariantColor
                    font_style: "ubuntu_title"
                    role: "large"
                    adaptive_size: True
                    size: self.texture_size[0], self.texture_size[1]
                    id: current_rain_amount

            #current icon and temperature
            MDBoxLayout:
                orientation: "horizontal"
                size_hint: None, None
                halign: "center"
                adaptive_width: True
                height: dp(270)
                padding: dp(0), dp(0), dp(20), dp(55)
                spacing: dp(65)
                pos_hint: {'center_x': 0.55}

                Label:
                    font_name: "Material-Icons"
                    text: "\ue430" #wb_sunny
                    font_size: dp(100)
                    color: app.theme_cls.onSurfaceVariantColor
                    adaptive_width: True
                    id: current_icon


                MDLabel:
                    text: "none"
                    font_style: "ubuntu_title_bold"
                    theme_font_size: "Custom"
                    font_size: dp(80)
                    markup: True
                    color: app.theme_cls.onSurfaceVariantColor
                    adaptive_width: True
                    id: temp_current

            #current stats
            MDCard:
                theme_bg_color: "Custom"
                style: "filled"
                size_hint: 0.9, None
                height: dp(120)
                radius: dp(52)
                pos_hint: {'center_x': 0.5}
                opacity: 0.72
                md_bg_color: app.theme_cls.secondaryContainerColor

                AnchorLayout:
                    anchor_x: "center"
                    anchor_y: "center"

                    MDBoxLayout:
                        adaptive_width: True
                        height: dp(100)
                        orientation: "horizontal"
                        spacing: dp(24)
                        padding: dp(20), dp(0)

                        # --- Humidity ---
                        MDGridLayout:
                            cols: 2 if root.width > dp(465) else 1
                            adaptive_size: True
                            spacing: dp(14)
                            pos_hint: {'center_y': 0.5}

                            Label:
                                font_name: "Material-Icons"
                                text: "\ue798"
                                font_size: dp(28)
                                color: app.theme_cls.onSecondaryContainerColor
                                pos_hint: {'center_y': 0.5}
                                adaptive_size: True

                            MDLabel:
                                id: current_humidity
                                text: "none"
                                color: app.theme_cls.onSecondaryContainerColor
                                font_style: "Display"
                                role: "small"
                                adaptive_size: True

                        MDDivider:
                            orientation: "vertical"
                            size_hint: None, 0.6
                            pos_hint: {'center_y': 0.5}

                        # --- Cloud Cover ---
                        MDGridLayout:
                            cols: 2 if root.width > dp(465) else 1
                            adaptive_size: True
                            spacing: dp(14)
                            pos_hint: {'center_y': 0.5}

                            Label:
                                font_name: "Material-Icons"
                                text: "\ue42d"
                                font_size: dp(28)
                                color: app.theme_cls.onSecondaryContainerColor
                                pos_hint: {'center_y': 0.5}
                                adaptive_size: True

                            MDLabel:
                                id: current_cloud
                                text: "none"
                                color: app.theme_cls.onSecondaryContainerColor
                                font_style: "Display"
                                role: "small"
                                adaptive_size: True

                        MDDivider:
                            orientation: "vertical"
                            size_hint: None, 0.6
                            pos_hint: {'center_y': 0.5}

                        # --- Wind speed (maybe idk at this point) ---
                        MDGridLayout:
                            cols: 2 if root.width > dp(465) else 1
                            adaptive_size: True
                            spacing: dp(14)
                            pos_hint: {'center_y': 0.5}

                            Label:
                                font_name: "Material-Icons"
                                text: "\uec0c"
                                font_size: dp(28)
                                color: app.theme_cls.onSecondaryContainerColor
                                pos_hint: {'center_y': 0.5}
                                adaptive_size: True

                            MDBoxLayout:
                                orientation: "vertical"
                                adaptive_size: True
                                spacing: dp(1)
                                pos_hint: {'center_y': 0.5}

                                MDLabel:
                                    id: current_wind_speed
                                    text: "none"
                                    color: app.theme_cls.onSecondaryContainerColor
                                    font_style: "Display"
                                    role: "small"
                                    pos_hint: {'center_y': 0.5}
                                    adaptive_size: True

                                MDLabel:
                                    text: "km/h"
                                    color: app.theme_cls.onSecondaryContainerColor
                                    font_style: "ubuntu_title"
                                    role: "medium"
                                    adaptive_size: True

            MDCard:
                style: "filled"
                size_hint: 0.95, None
                height: dp(140)
                pos_hint: {"center_x": 0.5}
                orientation: "vertical"
                spacing: dp(1)
                id: forecast_card

				#small label
				MDLabel:
					padding: [dp(8), dp(0.35), dp(0.35), dp(8)]
					text: "Hourly"
					font_style: "ubuntu_title"
					role: "medium"
					adaptive_height: True
					adaptive_width: True
					halign: "left"

                RecycleViewBoxThing:
                    id: forecast_panel

            MDBoxLayout:
                orientation: "horizontal"
                padding: dp(2)
                spacing: dp(10)
                size_hint_x: 0.95
